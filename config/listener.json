{
  "listen": {
    "mode": "session",
    "targets": ["ssh 前端进阶交流群3群「禁广告」", "哈佛", "街道工作者交流群"],
    "interval_seconds": 1.0,
    "dedupe_window_seconds": 2.5,
    "session_preview_dedupe_window_seconds": 20.0,
    "cross_source_merge_window_seconds": 3.0,
    "focus_refresh": false,
    "worker_debug": false
  },
  "translate": {
    "enabled": true,
    "provider": "deeplx",
    "source_lang": "auto",
    "target_lang": "EN",
    "timeout_seconds": 8.0
  },
  "display": {
    "english_only": true,
    "on_translate_fail": "show_cn_with_reason",
    "width": 420,
    "side": "right"
  },
  "logging": {
    "file": "logs/sidebar_listener.log"
  }
}
